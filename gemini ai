    print("\n[Phase 1: The Foundations]")
    print("Before Gemini, Google had LaMDA and PaLM 2.")
    print("They were great at talking, but Google wanted something BIGGER.")
    time.sleep(2)

    # 2. The Merger
    print("\n[Phase 2: The Big Merger (2023)]")
    print("Google Brain + DeepMind = Google DeepMind.")
    print("The smartest minds joined forces to build one model to rule them all.")
    time.sleep(2)

    # 3. Birth of Gemini
    print("\n[Phase 3: The Birth of Gemini (Multimodal)]")
    print("Gemini was born! Unlike older AI, it can see, hear, read, and code.")
    print("It comes in 4 sizes: Ultra, Pro, Flash, and Nano.")
